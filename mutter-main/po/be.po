#: data/50-mutter-system.xml:6 data/50-mutter-wayland.xml:6
msgid "System"
msgstr "Сістэма"

#: data/50-mutter-system.xml:8
msgid "Show the run command prompt"
msgstr "Паказаць акно для выканання каманды"

#: data/50-mutter-wayland.xml:8
